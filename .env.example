# Base URL del cliente HTTP. Por defecto relativo (/api): en dev lo proxea
# vite a VITE_API_PROXY_TARGET, en prod lo proxea nginx al backend. Solo
# cambialo si el frontend apunta a un backend en otro origen.
VITE_API_URL=/api

# Solo dev: a donde apunta el proxy de vite para /api.
VITE_API_PROXY_TARGET=http://localhost:3000
