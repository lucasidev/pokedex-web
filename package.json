{
  "name": "pokedex-web",
  "version": "2.0.0",
  "description": "Pokedex web client: JWT auth, pokedex and team management against the pokedex-api",
  "author": "Lucas Iriarte <lucasdiriarte@gmail.com>",
  "license": "ISC",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sbom": "cyclonedx-npm --output-format JSON --output-file sbom.json",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "msw": "^2.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
